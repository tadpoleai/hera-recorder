<launch>
<!-- <param name="/use_sim_time" value="true" />  -->
  <param name="robot_description"
    textfile="$(find carto_ros)/urdf/my_robot_2d.urdf" />

  <node name="robot_state_publisher" pkg="robot_state_publisher"
    type="robot_state_publisher" />

  <node name="carto_node" pkg="carto_ros"
      type="carto_node" args="
          -configuration_directory $(find carto_ros)/configuration_files
          -configuration_basename my_robot_2d.lua"
      output="screen">
    <remap from="scan" to="laserscan" />
    <remap from="imu" to="imu/raw_data" />
  </node>

  <node name="carto_occupancy_grid_node" pkg="carto_ros"
      type="carto_occupancy_grid_node" args="-resolution 0.1" />
</launch>
